{
  "expo": {
    "name": "MDZen",
    "slug": "MDZen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0FDF4"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0FDF4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "mimeType": "text/markdown" },
            { "mimeType": "text/x-markdown" },
            { "scheme": "file", "pathPattern": ".*\\.md" },
            { "scheme": "content", "pathPattern": ".*\\.md" },
            { "scheme": "file", "pathPattern": ".*\\.markdown" },
            { "scheme": "content", "pathPattern": ".*\\.markdown" }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "mdzen",
    "extra": {
      "eas": {
        "projectId": "4f7d796a-b6fc-4e33-ae20-083cede64e67"
      }
    },
    "owner": "advramzes",
    "plugins": [
      "expo-router"
    ]
  }
}
